# apps/api example environment variables
# Copy this to apps/api/.env and fill values before running the API

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/lms?retryWrites=true&w=majority

# JWT
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Client
CLIENT_ORIGIN=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
COOKIE_SECURE=false

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (SMTP)
EMAIL_USER=you@example.com
EMAIL_PASS=your_email_password
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_FROM="LMS <noreply@example.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="LMS <noreply@example.com>"

# Twilio SMS
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_OTP_CONTENT_SID=
TWILIO_FROM_NUMBER=+12345678900
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WEBHOOK_AUTH_TOKEN=
EXTERNAL_WEBHOOK_URL=
WIREWEB_WEBHOOK_TOKEN=

# Server
NODE_ENV=development
PORT=5000
LOCAL_UPLOAD_DIR=uploads
SERVER_ORIGIN=http://localhost:5000
