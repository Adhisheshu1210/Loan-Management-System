{
  "name": "loan-management-system",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @lms/web",
    "dev:api": "npm run dev --workspace @lms/api",
    "dev:web": "npm run dev --workspace @lms/web",
    "build": "npm run build --workspace @lms/web && npm run build --workspace @lms/api",
    "lint": "npm run lint --workspace @lms/web && npm run lint --workspace @lms/api",
    "seed": "npm run seed --workspace @lms/api"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}